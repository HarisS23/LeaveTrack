@page
@model LeaveTrack.Web.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Dashboard</h2>

    <!-- Stats Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card p-4 text-center">
                <h3 class="mb-1 text-warning">@Model.PendingCount</h3>
                <span class="text-muted">Pending Requests</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-4 text-center">
                <h3 class="mb-1 text-success">@Model.ApprovedCount</h3>
                <span class="text-muted">Approved Requests</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-4 text-center">
                <h3 class="mb-1 text-danger">@Model.RejectedCount</h3>
                <span class="text-muted">Rejected Requests</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-4 text-center">
                <h3 class="mb-1 text-secondary">@Model.TotalEmployees</h3>
                <span class="text-muted">Total Employees</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Pending Requests -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Pending Requests</h5>
                    <a asp-page="/Manager/Index" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Type</th>
                                <th>From</th>
                                <th>Days</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.RecentPending.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">
                                        No pending requests.
                                    </td>
                                </tr>
                            }
                            @foreach (var request in Model.RecentPending)
                            {
                                <tr>
                                    <td>@request.Employee.FirstName @request.Employee.LastName</td>
                                    <td>@request.LeaveType.PrettyName</td>
                                    <td>@request.StartDate.ToString("dd MMM yyyy")</td>
                                    <td>@((request.EndDate - request.StartDate).Days + 1)</td>
                                    <td>
                                        <a asp-page="/LeaveRequests/Detail"
                                           asp-route-id="@request.Id"
                                           class="btn btn-sm btn-outline-secondary">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Upcoming Leave -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Upcoming Leave (30 days)</h5>
                    <a asp-page="/Admin/Reports/Index" class="btn btn-sm btn-outline-primary">Full Report</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Type</th>
                                <th>From</th>
                                <th>Days</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.UpcomingLeave.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">
                                        No upcoming leave.
                                    </td>
                                </tr>
                            }
                            @foreach (var request in Model.UpcomingLeave)
                            {
                                <tr>
                                    <td>@request.Employee.FirstName @request.Employee.LastName</td>
                                    <td>@request.LeaveType.PrettyName</td>
                                    <td>@request.StartDate.ToString("dd MMM yyyy")</td>
                                    <td>@((request.EndDate - request.StartDate).Days + 1)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>