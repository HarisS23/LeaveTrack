@page
@model LeaveTrack.Web.Pages.Admin.Employees.CreateModel
@{
    ViewData["Title"] = "Add Employee";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Add Employee</h2>
        <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>

    <div class="card p-4" style="max-width: 600px;">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label class="form-label">First Name</label>
                <input asp-for="Employee.FirstName" class="form-control" required />
                <span asp-validation-for="Employee.FirstName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Last Name</label>
                <input asp-for="Employee.LastName" class="form-control" required />
                <span asp-validation-for="Employee.LastName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Employee.Email" type="email" class="form-control" required />
                <span asp-validation-for="Employee.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Role</label>
                <select asp-for="Employee.RoleId" asp-items="Model.RoleList" class="form-select" required>
                    <option value="">-- Select Role --</option>
                </select>
                <span asp-validation-for="Employee.RoleId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Yearly Leave Balance (days)</label>
                <input asp-for="Employee.YearlyLeaveBalance" type="number"
                       class="form-control" min="0" max="365" required />
                <span asp-validation-for="Employee.YearlyLeaveBalance" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Add Employee</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}