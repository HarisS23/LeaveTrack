@page
@model LeaveTrack.Web.Pages.Balance.IndexModel
@{
    ViewData["Title"] = "Leave Balance";
}

<div class="container mt-4">
    <h2 class="mb-4">Leave Balance</h2>

    <div class="card mb-4 p-3" style="max-width: 400px;">
        <label class="form-label">Select Employee</label>
        <select id="employeeSelect" class="form-select">
            <option value="">-- Select Employee --</option>
            @foreach (var employee in Model.Employees)
            {
                if (Model.SelectedEmployeeId == employee.Id)
                {
                    <option value="@employee.Id" selected>@employee.FirstName @employee.LastName</option>
                }
                else
                {
                    <option value="@employee.Id">@employee.FirstName @employee.LastName</option>
                }
            }
        </select>
    </div>

    @if (Model.SelectedEmployee != null)
    {
        <div class="row g-4" style="max-width: 800px;">
            <!-- Balance Card -->
            <div class="col-md-6">
                <div class="card p-4">
                    <h5 class="mb-3">@Model.SelectedEmployee.FirstName @Model.SelectedEmployee.LastName</h5>
                    <p class="text-muted mb-1">@Model.SelectedEmployee.Role.PrettyName</p>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Yearly allowance</span>
                        <strong>@Model.SelectedEmployee.YearlyLeaveBalance days</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Used</span>
                        <strong>@Model.UsedDays days</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Remaining</span>
                        <strong class="@(Model.RemainingBalance < 5 ? "text-danger" : "text-success")">
                            @Model.RemainingBalance days
                        </strong>
                    </div>
                    <div class="mt-3">
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar @(Model.RemainingBalance < 5 ? "bg-danger" : "bg-success")"
                                 role="progressbar"
                                 style="width: @(Model.UsedPercentage)%">
                            </div>
                        </div>
                        <small class="text-muted mt-1 d-block">@Model.UsedPercentage% used</small>
                    </div>
                </div>
            </div>

            <!-- Approved Requests -->
            <div class="col-md-6">
                <div class="card p-4">
                    <h5 class="mb-3">Approved Leave</h5>
                    @if (!Model.ApprovedRequests.Any())
                    {
                        <p class="text-muted">No approved leave requests.</p>
                    }
                    @foreach (var request in Model.ApprovedRequests)
                    {
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <div>
                                <span class="fw-500">@request.LeaveType.PrettyName</span>
                                <br />
                                <small class="text-muted">
                                    @request.StartDate.ToString("dd MMM") — @request.EndDate.ToString("dd MMM yyyy")
                                </small>
                            </div>
                            <span class="text-muted">
                                @((request.EndDate - request.StartDate).Days + 1) days
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.getElementById('employeeSelect').addEventListener('change', function () {
            const id = this.value;
            if (id) {
                window.location.href = '/Balance?employeeId=' + id;
            }
        });
    </script>
}