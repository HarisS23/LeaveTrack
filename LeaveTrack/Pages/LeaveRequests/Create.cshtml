@page
@model LeaveTrack.Web.Pages.LeaveRequests.CreateModel
@{
    ViewData["Title"] = "New Leave Request";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>New Leave Request</h2>
        <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>

    <div class="card p-4" style="max-width: 600px;">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label class="form-label">Employee</label>
                <select asp-for="Request.EmployeeId" asp-items="Model.EmployeeList"
                        class="form-select" required>
                    <option value="">-- Select Employee --</option>
                </select>
                <span asp-validation-for="Request.EmployeeId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Leave Type</label>
                <select asp-for="Request.LeaveTypeId" asp-items="Model.LeaveTypeList"
                        class="form-select" required>
                    <option value="">-- Select Leave Type --</option>
                </select>
                <span asp-validation-for="Request.LeaveTypeId" class="text-danger"></span>
            </div>

            <div class="row mb-3">
                <div class="col">
                    <label class="form-label">Start Date</label>
                    <input asp-for="Request.StartDate" type="date" class="form-control" />
                    <span asp-validation-for="Request.StartDate" class="text-danger"></span>
                </div>
                <div class="col">
                    <label class="form-label">End Date</label>
                    <input asp-for="Request.EndDate" type="date" class="form-control" />
                    <span asp-validation-for="Request.EndDate" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Comment <span class="text-muted">(optional)</span></label>
                <textarea asp-for="Request.Comment" class="form-control" rows="3" placeholder="Any additional notes..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Submit Request</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const startDateInput = document.getElementById('Request_StartDate');
        const endDateInput = document.getElementById('Request_EndDate');

        const tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1);
        const tomorrowStr = tomorrow.toISOString().split('T')[0];
        startDateInput.min = tomorrowStr;

        endDateInput.min = tomorrowStr;

        startDateInput.addEventListener('change', function () {
            const selectedStart = this.value;

            endDateInput.min = selectedStart;

            if (endDateInput.value && endDateInput.value < selectedStart) {
                endDateInput.value = selectedStart;
            }
        });

        document.querySelector('form').addEventListener('submit', function (e) {
            const employeeId = document.getElementById('Request_EmployeeId').value;
            const leaveTypeId = document.getElementById('Request_LeaveTypeId').value;
            const startDate = startDateInput.value;
            const endDate = endDateInput.value;

            if (!employeeId || !leaveTypeId || !startDate || !endDate) {
                e.preventDefault();

                if (!employeeId)
                    document.getElementById('Request_EmployeeId')
                        .classList.add('is-invalid');

                if (!leaveTypeId)
                    document.getElementById('Request_LeaveTypeId')
                        .classList.add('is-invalid');

                if (!startDate)
                    startDateInput.classList.add('is-invalid');

                if (!endDate)
                    endDateInput.classList.add('is-invalid');
            }
        });

        document.getElementById('Request_EmployeeId')
            .addEventListener('change', function () {
                this.classList.remove('is-invalid');
            });

        document.getElementById('Request_LeaveTypeId')
            .addEventListener('change', function () {
                this.classList.remove('is-invalid');
            });

        startDateInput.addEventListener('change', function () {
            this.classList.remove('is-invalid');
        });

        endDateInput.addEventListener('change', function () {
            this.classList.remove('is-invalid');
        });
    </script>
}